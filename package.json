{
  "name": "devbox",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"pnpm dev:web\" \"pnpm dev:api\"",
    "dev:web": "dotenv -e .env -- pnpm --filter @devbox/web dev",
    "dev:api": ".venv\\Scripts\\python -m uvicorn app.main:app --reload --app-dir services/api --port 8000",
    "build": "pnpm --filter @devbox/web build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm api:test",
    "api:test": ".venv\\Scripts\\python -m pytest services/api/tests",
    "api:openapi": ".venv\\Scripts\\python services/api/scripts/export_openapi.py",
    "generate:openapi": ".venv\\Scripts\\python services/api/scripts/export_openapi.py --output services/api/openapi.json && pnpm --filter @devbox/shared generate"
  },
  "devDependencies": {
    "concurrently": "9.2.1",
    "dotenv-cli": "^11.0.0",
    "openapi-typescript": "7.10.1",
    "typescript": "5.9.3"
  }
}
