{
  "name": "@devbox/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./openapi": "./src/openapi-types.ts"
  },
  "scripts": {
    "generate": "openapi-typescript ../../services/api/openapi.json -o src/openapi-types.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "openapi-typescript": "7.10.1",
    "typescript": "5.9.3"
  }
}
