NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
DEVBOX_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
DEVBOX_TARGET_AGENT_BASE_URL=http://localhost:8010

# Optional provider enablement. The MVP validates presence and keeps calls simulated.
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LOCAL_MODEL_BASE_URL=http://localhost:11434

# Google Managed Agents wrapper. DEVBOX_GENAI_MODE can be auto, simulator, or live.
DEVBOX_GENAI_MODE=auto
DEVBOX_MANAGED_AGENT_ID=antigravity-preview-05-2026
DEVBOX_REMOTE_NETWORK_ALLOWLIST=

# FastAPI -> Next.js signed PR webhook.
DEVBOX_GITHUB_WEBHOOK_URL=http://localhost:3000/api/github/webhook
DEVBOX_PR_WEBHOOK_SECRET=

# Next.js Octokit GitHub App configuration.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=
GITHUB_REPOSITORY=PeytonLi/DevBox
GITHUB_BASE_BRANCH=main
DEVBOX_TARGET_PROMPT_PATH=.agents/AGENTS.md
